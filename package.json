{
  "name": "@nuintun/bundler",
  "version": "4.1.0",
  "description": "An async file dependency bundle parser.",
  "type": "module",
  "sideEffects": false,
  "main": "cjs/index.cjs",
  "module": "esm/index.js",
  "exports": {
    ".": {
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs",
      "default": "./esm/index.js"
    }
  },
  "files": [
    "cjs",
    "esm"
  ],
  "engines": {
    "node": ">=7.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuintun/bundler.git"
  },
  "keywords": [
    "bundler"
  ],
  "author": {
    "name": "nuintun",
    "email": "nuintun@qq.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nuintun/bundler/issues"
  },
  "homepage": "https://github.com/nuintun/bundler#readme",
  "scripts": {
    "lint": "tsc --noEmit",
    "pretest": "pnpm build",
    "clean": "node tools/clean.ts",
    "prepublishOnly": "pnpm build",
    "test": "node tests/index.ts --cycle",
    "build:cjs": "rollup -c tools/rollup.cjs.ts",
    "build:esm": "rollup -c tools/rollup.esm.ts",
    "build:fix-types": "node tools/fix-types.ts",
    "build": "pnpm clean && pnpm build:main && pnpm format",
    "format": "prettier --write . --ignore-path .prettierignore",
    "build:main": "pnpm build:cjs && pnpm build:esm && pnpm build:fix-types"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "dts-paths": "^2.2.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "typescript": "^6.0.2"
  }
}
